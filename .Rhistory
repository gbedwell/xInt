#'@param n.cores The number of cores to use.
#'
#'@export
#'
getSeq_list <- function(genome.obj, names, as.character = FALSE, n.cores){
require(parallel)
if (missing(n.cores)){
n.cores <- parallel::detectCores()/2
}
seqs.list <- list()
seqs.list <- mclapply(X = seq_along(names),
FUN = function(x){
getSeq(x = genome.obj,
names = names[[x]],
as.character = as.character)},
mc.cores = n.cores
)
return(seqs.list)
}
