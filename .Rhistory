}
sites.list <- list()
sites.list <- mclapply(X = 1:n.iterations,
FUN = function(x){
xInt::random_sites(n.sites = n.sites,
genome.obj = genome.obj)}
)
if (isTRUE(collapse)){
sites.list <- do.call(c, sites.list)
}
return(sites.list)
}
